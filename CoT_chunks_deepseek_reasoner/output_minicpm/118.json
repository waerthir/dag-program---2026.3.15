      ],
      "intermediate_steps": [
        {
          "id": "I_1",
          "type": "数值计算",
          "content": "计算波函数的平方 |ψ(x)|^2 = A^2 x^2 (L-x)^2。",
          "parents": [
            "C_1"
          ],
          "reasoning_logic": "基于波函数定义计算平方。"
        },
        {
          "id": "I_2",
