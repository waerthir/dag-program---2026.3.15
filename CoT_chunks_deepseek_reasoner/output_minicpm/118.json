          ],
          "reasoning_logic": "从方程中提取积分部分进行计算。"
        },
        {
          "id": "I_4",
          "type": "数值计算",
          "content": "分解积分 ∫0^L x^2 (L-x)^2 dx = ∫0^L x^2 (L^2 - 2Lx + x^2) dx。",
          "parents": [
            "I_3"
          ],
          "reasoning_logic": "展开平方项。"
        },
        {
          "id": "I_5",
          "type": "数值计算",
          "content": "计算 ∫0^L x^2 L^2 dx = L^3 ∫0^L x^2 dx。",
          "parents": [
            "I_4"
          ],
          "reasoning_logic": "提取常数并积分。"
        },
        {
          "id": "I_6",
          "type": "数值计算",
          "content": "计算 ∫0^L Lx^2 dx = L^2 ∫0^L x^2 dx。",
          "parents": [
            "I_4"
          ],
          "reasoning_logic": "提取常数并积分。"
        },
        {
          "id": "I_7",
          "type": "数值计算",
          "content": "计算 ∫0^L x^4 dx = L^5/5。",
