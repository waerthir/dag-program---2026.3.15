          ],
          "reasoning_logic": "直接积分。"
        },
        {
          "id": "I_8",
          "type": "数值计算",
          "content": "计算 ∫0^L x^2 dx = L^3/3。",
          "parents": [
            "I_4"
          ],
          "reasoning_logic": "计算基本积分。"
        },
        {
          "id": "I_9",
          "type": "数值计算",
          "content": "所以 ∫0^L x^2 (L-x)^2 dx = L^3 · L^3/3 - 2L^2 · L^3/3 + L^5/5。",
          "parents": [
            "I_5",
            "I_6",
            "I_7",
