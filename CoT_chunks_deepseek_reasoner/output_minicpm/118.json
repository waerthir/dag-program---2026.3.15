            "I_9"
          ],
          "reasoning_logic": "简化表达式。"
        },
        {
          "id": "I_11",
          "type": "条件转化",
          "content": "代入归一化条件：L^6/3 - 2L^5/3 + L^5/5 = 1。",
          "parents": [
            "I_10",
            "I_2"
          ],
          "reasoning_logic": "将积分值代入归一化条件方程。"
        },
        {
          "id": "I_12",
          "type": "数值计算",
          "content": "求解 A：A = √(3 / (L^6/3 - 2L^5/3 + L^5/5 - 1))。",
          "parents": [
            "I_11"
          ],
          "reasoning_logic": "从方程求解A。"
        }
