      "intermediate_steps": [
        {
          "id": "I_1",
          "type": "数值计算",
          "content": "当n=0时，能量为E_0 = (1/2)^2 * (h^2 / (2m)) = h^2 / (4m)。",
          "parents": [
            "C_8",
