          ],
          "reasoning_logic": "根据正态分布 N(mu, sigma^2) 的期望定义，mu=0。"
        },
        {
          "id": "I_2",
          "type": "条件转化",
          "content": "将 E[sin(B_t)] 转化为 E[sin(sqrt(t) * Z)]，其中 Z ~ N(0, 1)。",
          "parents": [
