            "C_3"
          ],
          "reasoning_logic": "利用布朗运动的缩放性质进行变量代换。"
        },
        {
          "id": "I_3",
          "type": "逻辑推导",
          "content": "由于 Z 服从标准正态分布（关于 0 对称）且 sin 是奇函数，sin(sqrt(t) * Z) 的分布关于 0 对称。",
          "parents": [
            "C_4",
            "C_5",
            "I_2"
