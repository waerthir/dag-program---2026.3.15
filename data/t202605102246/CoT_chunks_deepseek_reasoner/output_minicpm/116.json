      "conditions": [
        {
          "id": "C_1",
          "type": "学科常识",
          "content": "一维薛定谔方程描述了粒子在势能为零的势阱中的运动。"
        },
        {
          "id": "C_2",
          "type": "学科常识",
          "content": "对于无限深势阱，势能函数为零。"
        },
        {
          "id": "C_3",
          "type": "学科常识",
          "content": "薛定谔方程可以简化为：\\[ -\\frac{\\hbar^2}{2m} \\frac{d^2\\psi(x)}{dx^2} = E\\psi(x) \\]"
        },
        {
          "id": "C_4",
          "type": "学科常识",
          "content": "由于势阱是无限深的，粒子在势阱内的运动是周期性的。"
        },
        {
          "id": "C_5",
          "type": "学科常识",
          "content": "波函数在x=0处必须为零。"
        },
        {
          "id": "C_6",
          "type": "学科常识",
          "content": "波函数在x=a处必须为零。"
        },
        {
          "id": "C_7",
          "type": "学科常识",
          "content": "对于无限深势阱，波函数的形式为：\\[ \\psi(x) = A \\sin(kx) \\]"
        }
      ],
      "intermediate_steps": [
        {
          "id": "I_1",
          "type": "条件转化",
          "content": "将波函数\\[ \\psi(x) = A \\sin(kx) \\]代入薛定谔方程，得到：\\[ -\\frac{\\hbar^2}{2m} \\left( k^2 A \\sin(kx) \\right) = E A \\sin(kx) \\]",
          "parents": [
            "C_3",
            "C_7"
          ],
          "reasoning_logic": "引用薛定谔方程和波函数形式进行代入。"
        },
        {
          "id": "I_2",
          "type": "数值计算",
          "content": "解方程得到：\\[ k^2 = \\frac{2mE}{\\hbar^2} \\]",
          "parents": [
            "I_1"
          ],
          "reasoning_logic": "通过代数变换解方程。"
        },
        {
          "id": "I_3",
          "type": "数值计算",
          "content": "波数k表示为：\\[ k = \\sqrt{\\frac{2mE}{\\hbar^2}} \\]",
          "parents": [
            "I_2"
          ],
          "reasoning_logic": "从k^2表达式开方得到k。"
        },
        {
          "id": "I_4",
          "type": "逻辑推导",
          "content": "波函数在x=0处：\\[ \\psi(0) = A \\sin(0) = 0 \\]，满足边界条件。",
          "parents": [
            "C_7",
            "C_5"
