        {
          "id": "I_9",
          "type": "条件转化",
          "content": "能量E可以表示为：\\[ E = \\frac{\\hbar^2 k^2}{2m} \\]",
          "parents": [
            "I_2"
          ],
          "reasoning_logic": "从k² = 2mE/ħ²重新排列得到。"
        },
        {
          "id": "I_10",
          "type": "数值计算",
          "content": "将k的表达式代入\\[ E = \\frac{\\hbar^2 k^2}{2m} \\]，得到：\\[ E = \\frac{\\hbar^2 \\left( \\sqrt{\\frac{2mE}{\\hbar^2}} \\frac{n\\pi}{a} \\right)^2}{2m} \\]",
          "parents": [
            "I_8",
            "I_9"
          ],
          "reasoning_logic": "代入k进行代数运算。"
        },
        {
          "id": "I_11",
          "type": "数值计算",
          "content": "简化表达式得到：\\[ E = \\frac{\\hbar^2 n^2 \\pi^2}{2ma^2} \\]",
          "parents": [
