        {
          "id": "I_7",
          "type": "条件转化",
          "content": "正弦函数为零的条件是：\\[ \\sqrt{\\frac{2mE}{\\hbar^2}} a = n\\pi \\]，其中n是整数。",
          "parents": [
            "I_6"
          ],
          "reasoning_logic": "利用sin(θ)=0时θ=nπ的性质。"
        },
        {
          "id": "I_8",
          "type": "数值计算",
          "content": "波数k表示为：\\[ k = \\sqrt{\\frac{2mE}{\\hbar^2}} \\frac{n\\pi}{a} \\]",
