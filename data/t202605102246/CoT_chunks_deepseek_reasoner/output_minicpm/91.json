          "content": "r_n = -1 表示反面朝上。"
        },
        {
          "id": "C_4",
          "type": "学科常识",
          "content": "根据中心极限定理，当 n 足够大时，随机变量和的标准化形式近似服从正态分布。"
        },
        {
          "id": "C_5",
          "type": "学科常识",
          "content": "N(0,0) 是一个标准正态分布。"
        },
        {
          "id": "C_6",
          "type": "学科常识",
          "content": "标准正态分布的所有区域的概率和为1。"
        }
      ],
      "intermediate_steps": [
        {
          "id": "I_1",
          "type": "逻辑推导",
          "content": "由于R_n是1和-1的随机变量，其期望值E(R_n)=0。",
          "parents": [
            "C_1",
            "C_2",
            "C_3"
          ],
          "reasoning_logic": "基于抛硬币结果的定义推导期望值。"
        },
        {
          "id": "I_2",
          "type": "逻辑推导",
          "content": "E(∑(R_n/n)) = ∑E(R_n/n)。",
          "parents": [
            "I_1"
          ],
          "reasoning_logic": "引用期望的线性性质。"
        },
        {
          "id": "I_3",
          "type": "逻辑推导",
          "content": "∑E(R_n/n) = ∑(E(R_n)/n)。",
          "parents": [
            "I_2"
          ],
          "reasoning_logic": "将期望除以常数n。"
        },
        {
          "id": "I_4",
          "type": "数值计算",
          "content": "∑(E(R_n)/n) = ∑(0/n)。",
          "parents": [
            "I_3",
            "I_1"
          ],
          "reasoning_logic": "代入E(R_n)=0。"
        },
        {
          "id": "I_5",
          "type": "数值计算",
          "content": "∑(0/n) = 0。",
          "parents": [
            "I_4"
          ],
          "reasoning_logic": "计算求和得0。"
        },
        {
          "id": "I_6",
          "type": "条件转化",
          "content": "根据中心极限定理，当n足够大时，∑(R_n/n)近似服从N(0, σ²)。",
          "parents": [
            "I_5",
            "C_4"
          ],
          "reasoning_logic": "应用中心极限定理于期望为0的随机变量和。"
        },
        {
          "id": "I_7",
          "type": "逻辑推导",
          "content": "由于R_n是1和-1，R_n²=1。",
          "parents": [
            "C_2",
            "C_3"
          ],
          "reasoning_logic": "基于R_n的值计算平方。"
        },
        {
          "id": "I_8",
          "type": "逻辑推导",
          "content": "E(R_n²)=1。",
          "parents": [
            "I_7"
          ],
          "reasoning_logic": "由于R_n²恒为1，期望为1。"
        },
        {
          "id": "I_9",
          "type": "数值计算",
          "content": "Var(R_n) = E(R_n^2) - [E(R_n)]^2 = 1 - (-1)^2 = 0。",
          "parents": [
            "I_8",
            "I_1"
          ],
          "reasoning_logic": "计算方差。"
        },
        {
          "id": "I_10",
          "type": "数值计算",
          "content": "σ² = 0。",
          "parents": [
            "I_9"
          ],
          "reasoning_logic": "方差为0，所以σ²=0。"
        },
        {
          "id": "I_11",
          "type": "逻辑推导",
          "content": "所以∑(R_n/n)近似服从N(0,0)。",
          "parents": [
            "I_6",
            "I_10"
          ],
          "reasoning_logic": "代入σ²=0到正态分布。"
        },
        {
          "id": "I_12",
          "type": "逻辑推导",
          "content": "由于N(0,0)是标准正态分布，其概率和为1，因此P(∑(R_n/n) < ∞) = 1。",
          "parents": [
            "I_11",
            "C_5",
            "C_6"
          ],
          "reasoning_logic": "基于正态分布性质推导概率。"
        }
      ],
      "final_conclusion": {
        "id": "O",
        "type": "综合归纳",
        "content": "P(∑(R_n/n) < ∞) = 1。",
        "parents": [
          "I_12"
        ],
        "reasoning_logic": "总结最终结论。"
      }
    }
  }
