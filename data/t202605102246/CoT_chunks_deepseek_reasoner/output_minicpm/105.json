  "graph": {
    "graph_logic": {
      "conditions": [
        {
          "id": "C_1",
          "type": "文字条件",
          "content": "电子被限制在一个长度为L的一维箱子里。"
        },
        {
          "id": "C_2",
          "type": "文字条件",
          "content": "需要根据薛定谔方程求解可能的能量级和波函数。"
        },
        {
          "id": "C_3",
          "type": "文字条件",
          "content": "要求确定前三个能量状态下，电子在给定位置出现的概率。"
        },
        {
          "id": "C_4",
          "type": "学科常识",
          "content": "薛定谔方程的形式为 -ħ²/(2m) d²ψ/dx² + V(x)ψ = Eψ。"
        },
        {
          "id": "C_5",
          "type": "学科常识",
          "content": "ħ是约化普朗克常数。"
        },
        {
          "id": "C_6",
          "type": "学科常识",
          "content": "m是电子质量。"
        },
        {
          "id": "C_7",
          "type": "学科常识",
          "content": "V(x)是势函数。"
        },
        {
          "id": "C_8",
          "type": "学科常识",
          "content": "E是能量。"
        },
        {
          "id": "C_9",
          "type": "学科常识",
          "content": "ψ(x)是波函数。"
        },
        {
          "id": "C_10",
          "type": "学科常识",
          "content": "在一维箱中，势函数 V(x) 可以表示为：V(x) = 0 if 0 ≤ x ≤ L/2 and V(x) = 0 if L/2 ≤ x ≤ L。"
        }
      ],
      "intermediate_steps": [
        {
          "id": "I_1",
          "type": "条件转化",
          "content": "薛定谔方程简化为 -ħ²/(2m) d²ψ/dx² = Eψ(x)。",
          "parents": [
            "C_4",
            "C_10"
          ],
          "reasoning_logic": "结合势函数为0，简化方程。"
        },
        {
          "id": "I_2",
          "type": "逻辑推导",
          "content": "解简化后的二阶微分方程，得到波函数形式 ψ(x) = A sin(kx) + B cos(kx)。",
          "parents": [
            "I_1"
          ],
          "reasoning_logic": "求解微分方程。"
        },
        {
          "id": "I_3",
          "type": "条件转化",
          "content": "k = √(2mE/ħ²)。",
          "parents": [
            "I_1"
          ],
          "reasoning_logic": "从简化方程定义波数k。"
        },
        {
          "id": "I_4",
          "type": "逻辑推导",
          "content": "应用边界条件：在 x=0 处，ψ(0)=B=0；在 x=L 处，ψ(L)=A sin(kL)=0。",
          "parents": [
            "I_2",
            "C_1"
          ],
          "reasoning_logic": "代入边界条件。"
        },
        {
          "id": "I_5",
          "type": "逻辑推导",
          "content": "由 sin(kL)=0 得 kL = nπ，所以 k = nπ/L，n=1,2,3,...",
          "parents": [
            "I_4"
          ],
          "reasoning_logic": "解方程 sin(kL)=0。"
        },
        {
          "id": "I_6",
          "type": "数值计算",
          "content": "能量级 E_n = ħ²k²/(2m) = ħ² (nπ/L)² / (2m) = n²π²ħ²/(8mL²)。",
          "parents": [
            "I_3",
            "I_5",
            "C_5",
            "C_6"
          ],
          "reasoning_logic": "代入k和常数计算能量。"
        },
        {
          "id": "I_7",
          "type": "数值计算",
          "content": "波函数 ψ_n(x) = A_n sin(nπx/L) for n=1,2,3。",
          "parents": [
            "I_2",
            "I_5"
          ],
          "reasoning_logic": "结合波函数形式和k值。"
        },
        {
          "id": "I_8",
          "type": "数值计算",
          "content": "概率分布 P(x) = |ψ(x)|² = A_n² sin²(nπx/L) for n=1,2,3。",
          "parents": [
            "I_7"
          ],
          "reasoning_logic": "计算概率密度。"
        }
      ],
      "final_conclusion": {
        "id": "O",
        "type": "综合归纳",
        "content": "能量级：E1 = π²ħ²/(4mL²), E2 = π²ħ²/(mL²), E3 = 9π²ħ²/(4mL²)；波函数：ψ1(x)=A1 sin(πx/L), ψ2(x)=A2 sin(2πx/L), ψ3(x)=A3 sin(3πx/L)；概率分布：P(x)=A1² sin²(πx/L), P(x)=A2² sin²(2πx/L), P(x)=A3² sin²(3πx/L)。",
        "parents": [
          "I_6",
          "I_7",
          "I_8"
        ],
        "reasoning_logic": "综合所有推导结果得出最终答案。"
      }
    }
  }
