  "graph": {
    "graph_logic": {
      "conditions": [
        {
          "id": "C_1",
          "type": "文字信息",
          "content": "波函数 ψ(x) = Ax(L-x)，其中 0 ≤ x ≤ L。"
        },
        {
          "id": "C_2",
          "type": "学科常识",
          "content": "归一化常数 A 的定义是使得波函数在整个盒子内平方和为1，即 ∫₀ᴸ |ψ(x)|² dx = 1。"
        },
        {
          "id": "C_3",
          "type": "学科常识",
          "content": "∫₀ᴸ x² dx = [x³/3]₀ᴸ = L³/3。"
        },
        {
          "id": "C_4",
          "type": "学科常识",
          "content": "∫₀ᴸ x⁴ dx = [x⁵/5]₀ᴸ = L⁵/5。"
        },
        {
          "id": "C_5",
          "type": "学科常识",
          "content": "粒子在盒子中的能量为 E = h²/(8mL²)。"
        }
      ],
      "intermediate_steps": [
        {
          "id": "I_1",
          "type": "条件转化",
          "content": "计算波函数的平方 |ψ(x)|² = A² x² (L-x)²。",
          "parents": [
            "C_1"
          ],
          "reasoning_logic": "将波函数平方。"
        },
        {
          "id": "I_2",
          "type": "条件转化",
          "content": "将 |ψ(x)|² 代入归一化条件，得到 ∫₀ᴸ A² x² (L-x)² dx = 1。",
          "parents": [
            "C_2",
            "I_1"
          ],
          "reasoning_logic": "代入归一化条件。"
        },
        {
          "id": "I_3",
          "type": "条件转化",
          "content": "计算积分 ∫₀ᴸ x² (L-x)² dx。",
          "parents": [
            "I_2"
          ],
          "reasoning_logic": "提取积分部分。"
        },
        {
          "id": "I_4",
          "type": "条件转化",
          "content": "分解积分 ∫₀ᴸ x² (L-x)² dx = ∫₀ᴸ x² (L² - 2Lx + x²) dx。",
          "parents": [
            "I_3"
          ],
          "reasoning_logic": "展开平方项。"
        },
        {
          "id": "I_5",
          "type": "条件转化",
          "content": "分解积分 ∫₀ᴸ x² (L² - 2Lx + x²) dx = ∫₀ᴸ x² L² dx - 2∫₀ᴸ Lx² dx + ∫₀ᴸ x⁴ dx。",
          "parents": [
            "I_4"
          ],
          "reasoning_logic": "拆分积分项。"
        },
        {
          "id": "I_6",
          "type": "条件转化",
          "content": "∫₀ᴸ x² L² dx = L² ∫₀ᴸ x² dx。",
          "parents": [
            "I_5"
          ],
          "reasoning_logic": "提取常数 L²。"
        },
        {
          "id": "I_7",
          "type": "条件转化",
          "content": "∫₀ᴸ Lx² dx = L ∫₀ᴸ x² dx。",
          "parents": [
            "I_5"
          ],
          "reasoning_logic": "提取常数 L。"
        },
        {
          "id": "I_8",
          "type": "数值计算",
          "content": "∫₀ᴸ x² dx = L³/3。",
          "parents": [
            "C_3"
          ],
          "reasoning_logic": "引用积分公式计算。"
        },
        {
          "id": "I_9",
          "type": "数值计算",
          "content": "∫₀ᴸ x⁴ dx = L⁵/5。",
          "parents": [
            "C_4"
          ],
          "reasoning_logic": "引用积分公式计算。"
        },
        {
          "id": "I_10",
          "type": "数值计算",
          "content": "∫₀ᴸ x² L² dx = L² * (L³/3) = L⁵/3。",
          "parents": [
            "I_6",
            "I_8"
          ],
          "reasoning_logic": "代入计算。"
        },
        {
          "id": "I_11",
          "type": "数值计算",
          "content": "∫₀ᴸ Lx² dx = L * (L³/3) = L⁴/3。",
          "parents": [
            "I_7",
            "I_8"
          ],
          "reasoning_logic": "代入计算。"
        },
        {
          "id": "I_12",
          "type": "数值计算",
          "content": "∫₀ᴸ x² (L-x)² dx = L⁵/3 - 2 * (L⁴/3) + L⁵/5。",
          "parents": [
            "I_5",
            "I_10",
            "I_11",
            "I_9"
          ],
          "reasoning_logic": "组合积分结果。"
        },
        {
          "id": "I_13",
          "type": "数值计算",
          "content": "简化 ∫₀ᴸ x² (L-x)² dx = L⁶/3 - 2L⁵/3 + L⁵/5。",
          "parents": [
            "I_12"
          ],
          "reasoning_logic": "简化表达式。"
        },
        {
          "id": "I_14",
          "type": "条件转化",
          "content": "代入归一化条件：A² * (L⁶/3 - 2L⁵/3 + L⁵/5) = 1。",
          "parents": [
            "I_2",
            "I_13"
          ],
          "reasoning_logic": "将积分结果代入归一化条件。"
        },
        {
          "id": "I_15",
          "type": "数值计算",
          "content": "求解 A：A = √[1 / (L⁶/3 - 2L⁵/3 + L⁵/5)]。",
          "parents": [
            "I_14"
          ],
          "reasoning_logic": "解方程求 A。"
        },
        {
          "id": "I_16",
          "type": "数值计算",
          "content": "归一化常数 A 的表达式为 A = √[3 / (L⁶ - 2L⁵ + 3L⁵/5 - 3)]。",
          "parents": [
            "I_15"
          ],
          "reasoning_logic": "进一步简化表达式。"
        }
      ],
      "final_conclusion": {
        "id": "O",
        "type": "综合归纳",
        "content": "归一化常数 A 的表达式为 A = √[3 / (L⁶/3 - 2L⁵/3 + L⁵/5 - 1)]。粒子在盒子中的能量为 E = h²/(8mL²)。",
        "parents": [
          "I_16",
          "C_5"
        ],
        "reasoning_logic": "综合 A 的表达式和能量公式得出最终结论。"
      }
    }
  }
