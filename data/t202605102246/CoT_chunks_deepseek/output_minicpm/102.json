  "graph": {
    "graph_logic": {
      "conditions": [
        {
          "id": "C_1",
          "type": "文字信息",
          "content": "一个一维无限深势阱，势阱宽度为2 nm。"
        },
        {
          "id": "C_2",
          "type": "文字信息",
          "content": "粒子的质量为5x10^-26 kg。"
        },
        {
          "id": "C_3",
          "type": "学科常识",
          "content": "对于一维无限深势阱，波函数的形式为Ψ(x) = A sin(kx)。"
        },
        {
          "id": "C_4",
          "type": "学科常识",
          "content": "波函数在势阱边界处为零。"
        },
        {
          "id": "C_5",
          "type": "学科常识",
          "content": "能量公式为E = -ħ^2 / (2m) * (2k)^2，其中ħ为约化普朗克常数，m为粒子质量。"
        },
        {
          "id": "C_6",
          "type": "学科常识",
          "content": "约化普朗克常数ħ = 1.054 x 10^-34 J·s。"
        }
      ],
      "intermediate_steps": [
        {
          "id": "I_1",
          "type": "条件转化",
          "content": "2 nm = 2 x 10^-9 m。",
          "parents": [
            "C_1"
          ],
          "reasoning_logic": "将势阱宽度单位从纳米转换为米。"
        },
        {
          "id": "I_2",
          "type": "逻辑推导",
          "content": "波函数在势阱边界处为零，即Ψ(0) = Ψ(2 x 10^-9) = 0。",
          "parents": [
            "C_4",
            "I_1"
          ],
          "reasoning_logic": "应用边界条件到具体宽度。"
        },
        {
          "id": "I_3",
          "type": "逻辑推导",
          "content": "Ψ(0) = A sin(0) = 0，所以A ≠ 0。",
          "parents": [
            "C_3",
            "I_2"
          ],
          "reasoning_logic": "代入波函数形式到边界条件Ψ(0)。"
        },
        {
          "id": "I_4",
          "type": "逻辑推导",
          "content": "Ψ(2 x 10^-9) = A sin(2k x 10^-9) = 0。",
          "parents": [
            "C_3",
            "I_2"
          ],
          "reasoning_logic": "代入波函数形式到边界条件Ψ(2 x 10^-9)。"
        },
        {
          "id": "I_5",
          "type": "逻辑推导",
          "content": "因为A ≠ 0，所以sin(2k x 10^-9) = 0。",
          "parents": [
            "I_3",
            "I_4"
          ],
          "reasoning_logic": "由Ψ(2 x 10^-9) = 0和A ≠ 0推导出正弦项为零。"
        },
        {
          "id": "I_6",
          "type": "逻辑推导",
          "content": "2k x 10^-9 = nπ，其中n为整数。",
          "parents": [
            "I_5"
          ],
          "reasoning_logic": "由sin(2k x 10^-9) = 0推导出k的量子化条件。"
        },
        {
          "id": "I_7",
          "type": "条件转化",
          "content": "E = -ħ^2 / (2m) * (2k)^2 = -ħ^2 / (2m) * (nπ / (2 x 10^-9))^2。",
          "parents": [
            "C_5",
            "I_6"
          ],
          "reasoning_logic": "将能量公式中的k用量子化条件替换。"
        },
        {
          "id": "I_8",
          "type": "条件转化",
          "content": "E = -ħ^2 / (2m) * n^2π^2 / (4 x 10^-18)。",
          "parents": [
            "I_7"
          ],
          "reasoning_logic": "简化能量表达式。"
        },
        {
          "id": "I_9",
          "type": "数值计算",
          "content": "E = - (1.054 x 10^-34)^2 / (2 * 5 x 10^-26) * n^2π^2 / (4 x 10^-18)。",
          "parents": [
            "C_2",
            "C_6",
            "I_8"
          ],
          "reasoning_logic": "代入ħ和m的数值到能量公式。"
        },
        {
          "id": "I_10",
          "type": "数值计算",
          "content": "E = - (1.107 x 10^-68) / (10 x 10^-26) * n^2π^2 / (4 x 10^-18)。",
          "parents": [
            "I_9"
          ],
          "reasoning_logic": "计算ħ^2和分母2m。"
        },
        {
          "id": "I_11",
          "type": "数值计算",
          "content": "E = - 1.107 x 10^-42 * n^2π^2 / (4 x 10^-18)。",
          "parents": [
            "I_10"
          ],
          "reasoning_logic": "简化分数部分。"
        },
        {
          "id": "I_12",
          "type": "数值计算",
          "content": "E = - 2.7675 x 10^-27 * n^2π^2。",
          "parents": [
            "I_11"
          ],
          "reasoning_logic": "完成最终数值计算。"
        }
      ],
      "final_conclusion": {
        "id": "O",
        "type": "综合归纳",
        "content": "允许的能量状态为n^2π^2 * 2.7675 x 10^-27 J。每个能量状态的能量差为2.7675 x 10^-27 J。",
        "parents": [
          "I_12"
        ],
        "reasoning_logic": "由计算出的能量表达式归纳出最终能量状态和能量差。"
      }
    }
  }
