        },
        {
          "id": "C_4",
          "type": "学科常识",
          "content": "对于无限深势阱，粒子的波函数在势阱边界处为零，即ψ(x) = 0 在 x = 0 和 x = L"
        },
        {
          "id": "C_5",
          "type": "学科常识",
          "content": "在势阱内部，波函数满足薛定谔方程：iħ∂ψ/∂t = Hψ，其中H是哈密顿算符"
        },
        {
          "id": "C_6",
          "type": "学科常识",
          "content": "对于一维无限深势阱，哈密顿算符H = -ħ²/(2m) ∂²/∂x²"
        },
        {
          "id": "C_7",
          "type": "学科常识",
          "content": "薛定谔方程变为：iħ∂ψ/∂t = -ħ²/(2m) ∂²ψ/∂x²"
        },
        {
          "id": "C_8",
          "type": "学科常识",
          "content": "对于一维无限深势阱，解薛定谔方程得到：ψ(x) = A sin(kx) + B cos(kx)，其中k = √(2mE/ħ)"
        }
      ],
      "intermediate_steps": [
        {
          "id": "I_1",
          "type": "逻辑推导",
          "content": "由于ψ(0) = 0，得到B = 0",
