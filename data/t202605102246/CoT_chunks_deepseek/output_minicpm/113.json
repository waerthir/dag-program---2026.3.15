          "content": "粒子在简谐振荡器势能井中。"
        },
        {
          "id": "C_2",
          "type": "文字信息",
          "content": "粒子处于能量本征态，能量为E。"
        },
        {
          "id": "C_3",
          "type": "文字信息",
          "content": "求在势能等于最大势能的一半处的概率密度。"
        },
        {
          "id": "C_4",
          "type": "学科常识",
          "content": "简谐振荡器的势能公式为V(x) = (1/2)kx^2，其中k是弹簧常数。"
        },
        {
          "id": "C_5",
          "type": "学科常识",
          "content": "最大势能为V_max = (1/2)kL^2，其中L是势能井的长度。"
        },
        {
          "id": "C_6",
          "type": "学科常识",
          "content": "能量本征态为E_n = (n+1/2)^2 * (h^2 / (2m))，其中m是粒子的质量，h是普朗克常数。"
        },
        {
          "id": "C_7",
          "type": "学科常识",
          "content": "当n = 0时，能量为E_0 = (1/2)^2 * (h^2 / (2m)) = h^2 / (4m)。"
        },
        {
          "id": "C_8",
          "type": "学科常识",
          "content": "当n = 1时，能量为E_1 = (3/2)^2 * (h^2 / (2m)) = 9h^2 / (8m)。"
        },
        {
          "id": "C_9",
          "type": "学科常识",
          "content": "当n = 2时，能量为E_2 = (5/2)^2 * (h^2 / (2m)) = 25h^2 / (8m)。"
        },
        {
          "id": "C_10",
          "type": "学科常识",
          "content": "简谐振荡器的波函数为ψ_n(x) = sqrt(2/L) * sin(n * π * x / L)。"
        },
        {
          "id": "C_11",
          "type": "学科常识",
          "content": "能量本征态波函数为ψ_n(x) = sqrt(2/L) * sin((n+1/2) * π * x / L)。"
        },
        {
          "id": "C_12",
          "type": "学科常识",
          "content": "概率密度函数为|ψ_n(x)|^2 = (2/L) * sin^2((n+1/2) * π * x / L)。"
        }
      ],
      "intermediate_steps": [
        {
          "id": "I_1",
          "type": "条件转化",
          "content": "设势能为V(x) = (1/2)V_max = (1/2)(1/2)kL^2 = (1/4)kL^2。",
          "parents": [
            "C_3",
            "C_5"
          ],
          "reasoning_logic": "根据势能等于最大势能的一半的条件，转化出具体表达式。"
        },
        {
          "id": "I_2",
          "type": "条件转化",
          "content": "代入势能公式V(x) = (1/2)kx^2，得到(1/2)kx^2 = (1/4)kL^2。",
          "parents": [
            "C_4",
            "I_1"
          ],
          "reasoning_logic": "将势能表达式代入势能公式，建立方程。"
        },
        {
          "id": "I_3",
          "type": "数值计算",
          "content": "x^2 = L^2 / 2。",
          "parents": [
            "I_2"
          ],
          "reasoning_logic": "对方程进行代数变换，求解x^2。"
        },
        {
          "id": "I_4",
          "type": "数值计算",
          "content": "x = sqrt(L^2 / 2)。",
          "parents": [
            "I_3"
          ],
          "reasoning_logic": "对方程进行开方运算，求解x。"
        },
        {
          "id": "I_5",
          "type": "数值计算",
          "content": "|ψ_n(sqrt(L^2 / 2))|^2 = (2/L) * sin^2((n+1/2) * π * sqrt(L^2 / 2) / L)。",
          "parents": [
            "C_12",
            "I_4"
          ],
          "reasoning_logic": "将x的值代入概率密度函数。"
        },
        {
          "id": "I_6",
          "type": "数值计算",
          "content": "|ψ_n(sqrt(L^2 / 2))|^2 = (2/L) * sin^2((n+1/2) * π / sqrt(2))。",
          "parents": [
            "I_5"
          ],
          "reasoning_logic": "对表达式进行简化计算。"
        }
      ],
      "final_conclusion": {
        "id": "O",
        "type": "综合归纳",
        "content": "在势能等于最大势能的一半处的概率密度为|ψ_n(sqrt(L^2 / 2))|^2 = (2/L) * sin^2((n+1/2) * π / sqrt(2))。",
        "parents": [
          "I_6"
        ],
        "reasoning_logic": "综合计算步骤，得出最终概率密度表达式。"
      }
    }
  }
